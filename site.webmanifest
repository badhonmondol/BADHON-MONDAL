  "start_url": "/BADHON-MONDAL/",
  "scope": "/BADHON-MONDAL/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#030308",
  "theme_color": "#00f5ff",
  "categories": [
    "productivity",
    "developer"
  ],
  "screenshots": [
    {
      "src": "badhon.png",
      "sizes": "540x720",
      "type": "image/png",
      "form_factor": "narrow"
    },
    {
      "src": "badhon.png",
      "sizes": "1280x720",

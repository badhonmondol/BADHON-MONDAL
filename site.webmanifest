  "shortcuts": [
    {
      "name": "View Projects",
      "url": "/BADHON-MONDAL/#projects",
      "description": "Quick access to portfolio projects"
    },
    {
      "name": "Contact",
      "url": "/BADHON-MONDAL/#contact",
      "description": "Get in touch with Badhon"
    }
  ],
  "share_target": {
    "action": "/BADHON-MONDAL/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "/BADHON-MONDAL/",
      "accept": {
        "text/plain": [".txt"],
        "application/json": [".json"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+portfolio",
      "url": "/BADHON-MONDAL/?url=%s"
    }
  ],
  "prefer_related_applications": false,
  "related_applications": [],
  "scope_extensions": [
    {
      "origin": "https://badhonmondol.github.io"
    }
  ]
}